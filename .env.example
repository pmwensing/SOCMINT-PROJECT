SOCMINT_SECRET_KEY=replace-with-a-long-random-secret
SOCMINT_ADMIN_USER=admin
SOCMINT_ADMIN_PASSWORD=replace-with-a-strong-admin-password
SOCMINT_ALLOW_SIGNUP=true
SOCMINT_HTTPS=false
SOCMINT_DATA_DIR=/var/lib/socmint
SOCMINT_LOG_LEVEL=INFO
SOCMINT_TOR_PROXY=
SOCMINT_AUTO_CREATE_DB=false
SOCMINT_SIGNUP_INVITE_CODE=
SOCMINT_BACKUP_PASSPHRASE=replace-with-a-long-backup-passphrase
DATABASE_URL=sqlite:////var/lib/socmint/socmint.db

# Optional Postgres deployment:
# DATABASE_URL=postgresql+psycopg://socmint:change-this-postgres-password@postgres:5432/socmint
# POSTGRES_DB=socmint
# POSTGRES_USER=socmint
# POSTGRES_PASSWORD=change-this-postgres-password
