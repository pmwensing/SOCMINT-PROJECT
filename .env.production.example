# SOCMINT production environment template
SOCMINT_SECRET_KEY=change-me-generate-a-long-random-secret
SOCMINT_ADMIN_USER=admin
SOCMINT_ADMIN_PASSWORD=change-me-before-use
SOCMINT_ALLOW_SIGNUP=false
SOCMINT_HTTPS=true
SOCMINT_DATA_DIR=/var/lib/socmint
DATABASE_URL=sqlite:////var/lib/socmint/socmint.db
SOCMINT_BACKUP_PASSPHRASE=change-me-backup-passphrase
SOCMINT_TOR_SERVICE_DIR=/var/lib/tor/socmint_hidden_service
SOCMINT_BILLING_WEBHOOK_SECRET=change-me-webhook-secret
